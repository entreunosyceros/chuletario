{
    "Almacenamiento": [
        {
            "comando": "lsblk",
            "descripcion": "Árbol de discos y particiones",
            "ejemplo": "lsblk -f"
        },
        {
            "comando": "df",
            "descripcion": "Espacio usado en sistemas de archivos montados",
            "ejemplo": "df -hT"
        },
        {
            "comando": "du",
            "descripcion": "Espacio ocupado por directorios",
            "ejemplo": "du -sh /var/* | sort -h"
        },
        {
            "comando": "fdisk",
            "descripcion": "Particionar discos (MBR/GPT)",
            "ejemplo": "sudo fdisk -l"
        },
        {
            "comando": "parted",
            "descripcion": "Gestión de particiones (discos grandes)",
            "ejemplo": "sudo parted /dev/sdb print"
        },
        {
            "comando": "mkfs.ext4",
            "descripcion": "Formatear partición con ext4",
            "ejemplo": "sudo mkfs.ext4 /dev/sdb1"
        },
        {
            "comando": "blkid",
            "descripcion": "UUID y tipo de sistema de archivos",
            "ejemplo": "sudo blkid"
        },
        {
            "comando": "mount",
            "descripcion": "Montar sistema de archivos",
            "ejemplo": "sudo mount /dev/sdb1 /mnt/backup"
        },
        {
            "comando": "umount",
            "descripcion": "Desmontar partición o dispositivo",
            "ejemplo": "sudo umount /mnt/backup"
        },
        {
            "comando": "fstab",
            "descripcion": "Montajes permanentes al arranque (/etc/fstab)",
            "ejemplo": "sudo nano /etc/fstab",
            "notas": "Hay que tener cuidadín con modificar lo que no se debe"
        },
        {
            "comando": "fsck",
            "descripcion": "Comprobar y reparar sistema de archivos",
            "ejemplo": "sudo fsck -f /dev/sdb1"
        },
        {
            "comando": "lvm",
            "descripcion": "Volúmenes lógicos (pvcreate, vgcreate, lvcreate)",
            "ejemplo": "sudo pvdisplay && sudo vgdisplay && sudo lvdisplay"
        }
    ]
}